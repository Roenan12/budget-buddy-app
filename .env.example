# Supabase Configuration
# Project URL from Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=

# New format (Dashboard → Settings → API Keys):
# sb_secret_...     → server-side only (replaces service_role)
# sb_publishable_... → client-safe (replaces anon)
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Authentication
AUTH_URL=http://localhost:3000/
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000 